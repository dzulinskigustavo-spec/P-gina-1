// Seleciona os elementos do HTML
const botaoConquistar = document.getElementById('btn-conquistar');
const contadorTitulos = document.getElementById('contador-titulos');

// Cria a função que será executada no clique
botaoConquistar.addEventListener('click', () => {
    // Pega o número atual, transforma em número inteiro e soma 1
    let titulosAtuais = parseInt(contadorTitulos.textContent);
    titulosAtuais++;
    
    // Atualiza o texto na tela
    contadorTitulos.textContent = titulosAtuais;
    
    // Mensagem de comemoração
    alert('É CAMPEÃO! 🏆 O grito da torcida ecoa no estádio!');
});